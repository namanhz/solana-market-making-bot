{
  "name": "solana-market-making-bot",
  "version": "0.1.0",
  "description": "Lightweight Solana market-making bot for SPL token volume generation",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "generate-keyfile": "ts-node src/utils/KeyfileGenerator.ts generate",
    "verify-keyfile": "ts-node src/utils/KeyfileGenerator.ts verify",
    "docker:build": "docker build -t solana-mm-bot .",
    "docker:run": "docker run -p 3000:3000 -p 9090:9090 solana-mm-bot"
  },
  "keywords": [
    "solana",
    "market-making",
    "trading-bot",
    "defi",
    "jupiter",
    "spl-token"
  ],
  "author": "Market Making Team",
  "license": "MIT",
  "dependencies": {
    "@solana/spl-token": "^0.3.9",
    "@solana/web3.js": "^1.87.6",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "bs58": "^5.0.0",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "prom-client": "^15.1.0",
    "sqlite3": "^5.1.6",
    "winston": "^3.11.0",
    "ws": "^8.14.2",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.1",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
