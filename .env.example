# Solana Market-Making Bot Environment Configuration
# Copy this file to .env and customize with your actual values

# =============================================================================
# RPC Configuration
# =============================================================================

# Primary RPC endpoints (JSON array format)
SOLANA_RPC_ENDPOINTS=["https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY","https://solana-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY","https://rpc.ankr.com/solana"]

# WebSocket endpoint for real-time updates
SOLANA_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# =============================================================================
# DEX Configuration
# =============================================================================

# Jupiter API endpoint
JUPITER_API_URL=https://quote-api.jup.ag/v6

# Let's Bonk API endpoint
LETS_BONK_API_URL=https://api.letsbonk.com

# =============================================================================
# Security Configuration
# =============================================================================

# Encryption key for wallet keyfiles (MUST be 32+ characters)
# Generate a secure random key and keep it safe!
ENCRYPTION_KEY=CHANGE_THIS_TO_YOUR_SECURE_32_BYTE_ENCRYPTION_KEY_HERE

# Master passphrase for additional security (optional)
KEYSTORE_PASSPHRASE=your_secure_passphrase_here

# =============================================================================
# Trading Configuration
# =============================================================================

# Target token mint address
TARGET_TOKEN_MINT=So11111111111111111111111111111111111111112

# Minimum trade amount in SOL
MIN_TRADE_AMOUNT_SOL=0.001

# Maximum slippage in basis points (100 = 1%)
MAX_SLIPPAGE_BPS=100

# Liquidity threshold in USD for DEX selection
LIQUIDITY_THRESHOLD=1000

# =============================================================================
# Monitoring Configuration
# =============================================================================

# Prometheus metrics port
PROMETHEUS_PORT=9090

# REST API port
REST_API_PORT=3000

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# =============================================================================
# Rate Limiting
# =============================================================================

# Jupiter API rate limit (requests per second)
JUPITER_RATE_LIMIT=10

# RPC rate limit (requests per second)
RPC_RATE_LIMIT=100

# =============================================================================
# Development/Testing
# =============================================================================

# Set to true for development mode
DEV_MODE=false

# Set to true to enable dry-run mode (no actual trades)
DRY_RUN_MODE=false

# Network to use (mainnet-beta, devnet, testnet)
SOLANA_NETWORK=mainnet-beta

# =============================================================================
# Docker Configuration
# =============================================================================

# Container timezone
TZ=UTC

# Node environment
NODE_ENV=production

# =============================================================================
# Optional: External Services
# =============================================================================

# Solscan API key (for additional data)
SOLSCAN_API_KEY=your_solscan_api_key_here
SOLSCAN_API_URL=https://pro-api.solscan.io

# Webhook URL for notifications (optional)
WEBHOOK_URL=https://your-webhook-endpoint.com/notify

# =============================================================================
# Security Notes
# =============================================================================

# IMPORTANT SECURITY REMINDERS:
# 1. Never commit this file with real values to version control
# 2. Use strong, unique encryption keys
# 3. Regularly rotate API keys
# 4. Monitor access logs
# 5. Use environment-specific configurations
# 6. Keep backups of encryption keys in secure locations

# =============================================================================
# Example Values (REPLACE WITH YOUR OWN)
# =============================================================================

# Example Helius RPC (replace with your API key):
# SOLANA_RPC_ENDPOINTS=["https://mainnet.helius-rpc.com/?api-key=abc123def456"]

# Example Alchemy RPC (replace with your API key):
# SOLANA_RPC_ENDPOINTS=["https://solana-mainnet.g.alchemy.com/v2/your-api-key"]

# Example encryption key (generate your own 32+ character key):
# ENCRYPTION_KEY=my-super-secure-32-character-key-here-123456789

# Example target token (BONK token):
# TARGET_TOKEN_MINT=DezXAZ8z7PnrnRJjz3wXBoRgixCa6xjnB7YaB1pPB263
